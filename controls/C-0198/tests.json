[
    {
        "name": "Pod with runAsNonRoot is allowed",
        "template": "pod.yaml",
        "expected": "pass",
        "field_change_list": [
            "spec.containers.[0].securityContext.runAsNonRoot=true"
        ]
    },
    {
        "name": "Pod with runAsUser non-zero is allowed",
        "template": "pod.yaml",
        "expected": "pass",
        "field_change_list": [
            "spec.containers.[0].securityContext.runAsUser=1000"
        ]
    },
    {
        "name": "Pod with runAsUser set to 0 is blocked",
        "template": "pod.yaml",
        "expected": "fail",
        "field_change_list": [
            "spec.containers.[0].securityContext.runAsUser=0"
        ]
    },
    {
        "name": "Pod without securityContext is allowed",
        "template": "pod.yaml",
        "expected": "pass"
    },
    {
        "name": "Deployment with runAsNonRoot is allowed",
        "template": "deployment.yaml",
        "expected": "pass",
        "field_change_list": [
            "spec.template.spec.containers.[0].securityContext.runAsNonRoot=true"
        ]
    },
    {
        "name": "Deployment with runAsUser set to 0 is blocked",
        "template": "deployment.yaml",
        "expected": "fail",
        "field_change_list": [
            "spec.template.spec.containers.[0].securityContext.runAsUser=0"
        ]
    }
]
