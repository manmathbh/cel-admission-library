[
    {
        "name": "Pod without capabilities is allowed",
        "template": "pod.yaml",
        "expected": "pass"
    },
    {
        "name": "Pod with NET_RAW capability is blocked",
        "template": "pod-capabilities.yaml",
        "expected": "fail"
    },
    {
        "name": "Pod with only SYS_ADM capability (no NET_RAW) is allowed",
        "template": "pod-for-list-items.yaml",
        "expected": "pass"
    },
    {
        "name": "Deployment without capabilities is allowed",
        "template": "deployment.yaml",
        "expected": "pass"
    },
    {
        "name": "Deployment with NET_RAW capability is blocked",
        "template": "deployment-for-list-items.yaml",
        "expected": "fail"
    },
    {
        "name": "CronJob with NET_RAW capability is blocked",
        "template": "cronjob.yaml",
        "expected": "fail",
        "field_change_list": [
            "spec.jobTemplate.spec.template.spec.containers.[0].securityContext.capabilities.add=[\"NET_RAW\"]"
        ]
    },
    {
        "name": "Pod with initContainer having NET_RAW capability is blocked",
        "template": "pod.yaml",
        "expected": "fail",
        "field_change_list": [
            "spec.initContainers=[{\"name\":\"init\",\"image\":\"alpine\",\"command\":[\"sh\"],\"securityContext\":{\"capabilities\":{\"add\":[\"NET_RAW\"]}}}]"
        ]
    }
]
