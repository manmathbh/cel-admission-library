[
    {
        "name": "Pod without capabilities.drop is denied",
        "template": "pod.yaml",
        "expected": "fail"
    },
    {
        "name": "Pod with drop ALL is allowed",
        "template": "pod-drop-all.yaml",
        "expected": "pass"
    },
    {
        "name": "Pod with drop only NET_RAW (not ALL) is denied",
        "template": "pod-for-list-items.yaml",
        "expected": "fail"
    },
    {
        "name": "Deployment without capabilities.drop is denied",
        "template": "deployment.yaml",
        "expected": "fail"
    },
    {
        "name": "Deployment with drop ALL is allowed",
        "template": "deployment.yaml",
        "expected": "pass",
        "field_change_list": [
            "spec.template.spec.containers.[0].securityContext.capabilities.drop=[\"ALL\"]"
        ]
    },
    {
        "name": "Pod with initContainer lacking drop ALL is denied",
        "template": "pod-drop-all.yaml",
        "expected": "fail",
        "field_change_list": [
            "spec.initContainers=[{\"name\":\"init\",\"image\":\"alpine\",\"command\":[\"sh\"]}]"
        ]
    },
    {
        "name": "CronJob without capabilities.drop is denied",
        "template": "cronjob.yaml",
        "expected": "fail"
    },
    {
        "name": "CronJob with drop ALL is allowed",
        "template": "cronjob.yaml",
        "expected": "pass",
        "field_change_list": [
            "spec.jobTemplate.spec.template.spec.containers.[0].securityContext.capabilities.drop=[\"ALL\"]"
        ]
    },
    {
        "name": "Pod with both main and init containers dropping ALL is allowed",
        "template": "pod-drop-all.yaml",
        "expected": "pass",
        "field_change_list": [
            "spec.initContainers=[{\"name\":\"init\",\"image\":\"alpine\",\"command\":[\"sh\"],\"securityContext\":{\"capabilities\":{\"drop\":[\"ALL\"]}}}]"
        ]
    },
    {
        "name": "Pod with ephemeralContainer lacking drop ALL is denied",
        "template": "pod-drop-all.yaml",
        "expected": "fail",
        "field_change_list": [
            "spec.ephemeralContainers=[{\"name\":\"debug\",\"image\":\"alpine\",\"command\":[\"sh\"],\"targetContainerName\":\"sleep\"}]"
        ]
    },
    {
        "name": "Pod with ephemeralContainer dropping ALL is allowed",
        "template": "pod-drop-all.yaml",
        "expected": "pass",
        "field_change_list": [
            "spec.ephemeralContainers=[{\"name\":\"debug\",\"image\":\"alpine\",\"command\":[\"sh\"],\"targetContainerName\":\"sleep\",\"securityContext\":{\"capabilities\":{\"drop\":[\"ALL\"]}}}]"
        ]
    }
]
